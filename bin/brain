#!/usr/bin/env sh
# brain — the portable engine for the Agent Brain coordination vault.
# One POSIX sh script; no Claude-specific deps. Subcommands below; hooks call back in.
# v1: filesystem-only. Reads via built-in tools/Grep; writes via Write/Edit + this script's
# atomic append. See .context/AGENT-BRAIN-BUILD-SPEC.md for the authoritative design.
#
# Deviation note: macOS has no flock(1); `brain commit`/governance use an atomic mkdir lock
# (the portable equivalent — mkdir is atomic create on POSIX filesystems).

set -u
VERSION="1.0.0"

# ── Root discovery (fix A) — the one function everything reuses ───────────────────────────────
# --git-common-dir resolves to the MAIN worktree's .git from any sibling worktree, so the brain
# is always the one <main>/.brain/. Robust to a relative result (e.g. ".git" or "../.git").
brain_root() {
  _gcd=$(git rev-parse --git-common-dir 2>/dev/null) || return 1
  case "$_gcd" in
    /*) : ;;                                  # already absolute
    *)  _gcd=$(cd "$_gcd" 2>/dev/null && pwd -P) || return 1 ;;
  esac
  dirname "$_gcd"
}

# ── Small helpers ────────────────────────────────────────────────────────────────────────────
_now_iso()  { date -u +%Y-%m-%dT%H:%M:%SZ; }
_today()    { date -u +%Y-%m-%d; }
# Test seam: BRAIN_TEST_BRANCH overrides the resolved branch (used by the smoke test only).
_branch()   { printf '%s\n' "${BRAIN_TEST_BRANCH:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null)}"; }
_toplevel() { git rev-parse --show-toplevel 2>/dev/null; }
# integration branch the vault commits/diffs against; override with BRAIN_MAIN_REF (e.g. origin/master)
_main_ref()    { printf '%s\n' "${BRAIN_MAIN_REF:-origin/main}"; }
_main_remote() { _r=$(_main_ref); printf '%s\n' "${_r%%/*}"; }
_main_branch() { _r=$(_main_ref); printf '%s\n' "${_r#*/}"; }
_warn()     { printf 'brain: %s\n' "$*" >&2; }
_die()      { _warn "$*"; exit 1; }

# repo-root-relative path for an (absolute or relative) file path
_relpath() {
  case "$1" in
    "$ROOT"/*) printf '%s\n' "${1#"$ROOT"/}" ;;
    *)         printf '%s\n' "$1" ;;
  esac
}

# Read one frontmatter scalar (first match), stripping an inline "# comment" and trailing space.
# The colon after the key disambiguates feature/features, status/current_status, etc.
_fm() {
  awk -v key="$2" '
    /^---[[:space:]]*$/ { fence++; if (fence >= 2) exit; next }
    fence == 1 && index($0, key ":") == 1 {
      line = $0
      sub(/^[^:]*:[[:space:]]*/, "", line)
      sub(/[[:space:]]+#.*$/, "", line)
      sub(/[[:space:]]+$/, "", line)
      print line; exit
    }
  ' "$1" 2>/dev/null
}

# A YAML inline list ("[a, b]" / '["a","b"]') → space-separated bare tokens.
_list_field() {
  _fm "$1" "$2" | tr -d '[]' | tr -d '"' | tr -d "'" | tr ',' ' '
}
_owns_tokens() { _list_field "$1" owns_branches; }
_agent_slug()  { b=$(basename "$1"); printf '%s\n' "${b%.md}"; }

# Branch → positional slug (§2a): first token after the "<alpha>-<num>" ticket in feat/…; else
# the whole branch name. graph⊄langgraph and the cockpit double-match are killed by this + exact
# token equality in whoami.
_slug_from_branch() {
  case "$1" in
    feat/*)
      _rest=${1#feat/}
      _stripped=$(printf '%s' "$_rest" | sed -E 's/^[A-Za-z]+-[0-9]+-//')
      printf '%s\n' "$_stripped" | cut -d- -f1
      ;;
    *) printf '%s\n' "$1" ;;
  esac
}

# path vs declared path/zone — trailing "/" = zone (prefix); else exact file (fix D).
_path_match() {
  _p=$1; _t=$2
  case "$_t" in
    */) case "$_p" in "$_t"*) return 0 ;; esac; return 1 ;;
    *)  [ "$_p" = "$_t" ] && return 0; return 1 ;;
  esac
}

# Replace a single frontmatter key's value in place (inline form).
_set_fm_inline() {
  _f=$1; _k=$2; _v=$3
  awk -v key="$_k" -v val="$_v" '
    /^---[[:space:]]*$/ { fence++; print; next }
    fence == 1 && !done && index($0, key ":") == 1 { print key ": " val; done=1; next }
    { print }
  ' "$_f" > "$_f.tmp" && mv "$_f.tmp" "$_f"
}

# Atomic mkdir lock (flock replacement — macOS has no flock).
_lock_acquire() {
  _ld="$BRAIN/.locks/$1.lock"; mkdir -p "$BRAIN/.locks" 2>/dev/null
  _i=0
  while ! mkdir "$_ld" 2>/dev/null; do
    _i=$((_i + 1)); [ "$_i" -ge 50 ] && return 1; sleep 0.1
  done
  return 0
}
_lock_release() { rmdir "$BRAIN/.locks/$1.lock" 2>/dev/null || true; }

_kebab() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//'; }

_new_journal() {
  printf -- '---\ntype: journal\ndate: %s\n---\n\n' "$2" > "$1"
}

# ── Resolve the vault for the subcommands that need it ────────────────────────────────────────
_require_brain() {
  ROOT=$(brain_root) || _die "not inside a git repository"
  BRAIN="$ROOT/.brain"
  [ -d "$BRAIN" ] || _die "no brain here (run: brain init)"
}

# ── whoami (the single identity resolver) ────────────────────────────────────────────────────
cmd_whoami() {
  if [ -n "${BRAIN_FEATURE:-}" ]; then printf '%s\n' "$BRAIN_FEATURE"; return 0; fi
  ROOT=$(brain_root) || return 0
  BRAIN="$ROOT/.brain"; [ -d "$BRAIN" ] || return 0
  _slug=$(_slug_from_branch "$(_branch)"); [ -z "$_slug" ] && return 0

  _matches=""
  for _f in "$BRAIN"/presence/*.md; do
    [ -e "$_f" ] || continue
    for _tok in $(_owns_tokens "$_f"); do
      if [ "$_tok" = "$_slug" ]; then _matches="$_matches $(_agent_slug "$_f")"; fi
    done
  done
  # de-dupe
  _matches=$(printf '%s\n' $_matches | sort -u | tr '\n' ' ')
  set -- $_matches
  case $# in
    0) return 0 ;;                                  # empty = not a brain branch
    1) printf '%s\n' "$1"; return 0 ;;
    *)                                              # multi-match → tiebreak by current_worktree
      _top=$(_toplevel); _topc=$(cd "$_top" 2>/dev/null && pwd -P)
      for _m in "$@"; do
        _cw=$(_fm "$BRAIN/presence/$_m.md" current_worktree)
        _cwc=$(cd "$_cw" 2>/dev/null && pwd -P)     # canonicalize (handles /tmp→/private/tmp symlinks)
        if [ "$_cw" = "$_top" ] || { [ -n "$_cwc" ] && [ "$_cwc" = "$_topc" ]; }; then
          printf '%s\n' "$_m"; return 0
        fi
      done
      return 1 ;;                                   # still ambiguous → refuse (print nothing)
  esac
}

# ── announce (the single canonical journal writer) ───────────────────────────────────────────
cmd_announce() {
  _require_brain
  [ -n "${1:-}" ] || _die "usage: brain announce \"<msg>\""
  _feat=$(cmd_whoami); [ -z "$_feat" ] && _feat="${BRAIN_FEATURE:-system}"
  _day=$(_today); _jf="$BRAIN/journal/$_day.md"
  [ -f "$_jf" ] || _new_journal "$_jf" "$_day"
  printf -- '- %s %s — %s\n' "$(_now_iso)" "$_feat" "$1" >> "$_jf"   # atomic append
}

# ── status (the single live-state source) ────────────────────────────────────────────────────
_recent_journal() {
  _feat=$1; _jf="$BRAIN/journal/$(_today).md"
  [ -f "$_jf" ] || return 0
  grep -E "(^| )$_feat | @$_feat([^a-zA-Z]|$)" "$_jf" 2>/dev/null | tail -5
}

cmd_status() {
  _require_brain
  _me=$(cmd_whoami)
  printf '═══ Agent Brain — live state ═══\n'
  [ -n "$_me" ] && printf 'You are: %s\n' "$_me"

  printf '\nActive features:\n'
  for _f in "$BRAIN"/presence/*.md; do
    [ -e "$_f" ] || continue
    _st=$(_fm "$_f" status); _sl=$(_agent_slug "$_f")
    _ph=$(_fm "$_f" phase); _tk=$(_fm "$_f" current_ticket)
    case "$_st" in
      active|blocked) printf '  • %-18s [%s] %s %s\n' "$_sl" "$_st" "${_ph:-—}" "${_tk:+($_tk)}" ;;
      idle)           printf '  • %-18s [idle] (upcoming)\n' "$_sl" ;;
      *)              : ;;   # done/unknown skipped
    esac
  done

  printf '\nOpen/watch connections touching you:\n'
  _any=0
  for _c in "$BRAIN"/connections/*.md; do
    [ -e "$_c" ] || continue
    _st=$(_fm "$_c" status); case "$_st" in open|watch) ;; *) continue ;; esac
    _feats=$(_list_field "$_c" features)
    _hit=0
    if [ -n "$_me" ]; then
      for _x in $_feats; do [ "$_x" = "$_me" ] && _hit=1; done
    fi
    [ -z "$_me" ] && _hit=1     # no identity → show all open edges
    if [ "$_hit" = 1 ]; then
      _any=1
      printf '  • %-34s [%s/%s/%s] blocks:%s\n' \
        "$(_agent_slug "$_c")" "$(_fm "$_c" kind)" "$(_fm "$_c" severity)" "$_st" \
        "$(_list_field "$_c" blocks | tr -s ' ' | sed 's/^ *//;s/ *$//' | tr ' ' ',' )"
    fi
  done
  [ "$_any" = 0 ] && printf '  (none)\n'

  # CHANGES banner — "⚠ N brain changes since you last looked" (advances cursor on look)
  if [ -f "$BRAIN/CHANGES.md" ]; then
    _total=$(grep -c '^- ' "$BRAIN/CHANGES.md" 2>/dev/null || echo 0)
    _cur=0; _cf="$BRAIN/.cursors/${_me:-anon}.changes"
    [ -f "$_cf" ] && _cur=$(cat "$_cf" 2>/dev/null || echo 0)
    if [ "$_total" -gt "$_cur" ] 2>/dev/null; then
      printf '\n⚠ %s brain change(s) since you last looked — see .brain/CHANGES.md\n' \
        "$((_total - _cur))"
      mkdir -p "$BRAIN/.cursors"; printf '%s\n' "$_total" > "$_cf"
    fi
  fi

  # hook-error breadcrumbs
  [ -s "$BRAIN/.hook-errors.log" ] && \
    printf '\n⚠ hook errors logged — see .brain/.hook-errors.log\n'

  # recent journal lines relevant to me
  if [ -n "$_me" ]; then
    _rj=$(_recent_journal "$_me")
    if [ -n "$_rj" ]; then printf '\nRecent journal (you):\n%s\n' "$_rj"; fi
  fi
}

# ── new-feature (register a feature once) ────────────────────────────────────────────────────
cmd_new_feature() {
  _require_brain
  _slug=${1:-}; [ -n "$_slug" ] || _die "usage: brain new-feature <slug>"
  _note="$BRAIN/presence/$_slug.md"
  [ -f "$_note" ] && _die "feature already registered: $_slug"

  _br=$(_branch); _pslug=$(_slug_from_branch "$_br"); _top=$(_toplevel)
  _owns="\"$_slug\""
  if [ -n "$_pslug" ] && [ "$_pslug" != "$_slug" ]; then
    _owns="$_owns, \"$_pslug\""
    _warn "M6: branch slug ('$_pslug') ≠ feature ('$_slug') — added both to owns_branches; prefer the feature name in the branch going forward."
  fi

  _ts=$(_now_iso)
  cat > "$_note" <<EOF
---
type: presence
agent: $_slug
feature: "TODO"
status: idle
phase: TODO
owns_branches: [$_owns]
plan: TODO
tracker_epic: TODO
current_worktree: $_top
current_branch: $_br
current_ticket: TODO
touches: []
updated: $_ts
---
TODO: one paragraph — what this feature just did, what's next, [[links]] to connections touching its files.
EOF
  cmd_announce "joined — feature '$_slug' registered (status idle)"
  printf 'registered: %s\n' "$_note"
}

# ── reconcile (the coherence keeper) ─────────────────────────────────────────────────────────
cmd_reconcile() {
  _require_brain
  _check_only=0; [ "${1:-}" = "--check" ] && _check_only=1
  _errors=0

  # validate: every note parses + type allowlist (flags stealth-structural notes)
  for _f in "$BRAIN"/presence/*.md "$BRAIN"/connections/*.md "$BRAIN"/research/*.md; do
    [ -e "$_f" ] || continue
    _t=$(_fm "$_f" type)
    case "$_t" in
      presence|connection|research) ;;
      *) _warn "invalid/stealth type ('$_t') in ${_f#"$BRAIN"/}"; _errors=$((_errors + 1)) ;;
    esac
  done

  # colliding owns_branches tokens across features
  _seen=""
  for _f in "$BRAIN"/presence/*.md; do
    [ -e "$_f" ] || continue
    _sl=$(_agent_slug "$_f")
    for _tok in $(_owns_tokens "$_f"); do
      _prev=$(printf '%s\n' $_seen | grep "^$_tok=" | head -1)
      if [ -n "$_prev" ] && [ "${_prev#*=}" != "$_sl" ]; then
        _warn "owns_branches collision: token '$_tok' claimed by ${_prev#*=} and $_sl"
        _errors=$((_errors + 1))
      fi
      _seen="$_seen $_tok=$_sl"
    done
  done

  # dangling [[links]] (best-effort; warning only, not an error). Skip unfilled stubs whose
  # bracketed tokens are template placeholders (a note still carrying TODO isn't real yet).
  for _f in "$BRAIN"/presence/*.md "$BRAIN"/connections/*.md; do
    [ -e "$_f" ] || continue
    grep -q 'TODO' "$_f" 2>/dev/null && continue
    for _lnk in $(grep -oE '\[\[[a-z0-9-]+\]\]' "$_f" 2>/dev/null | tr -d '[]' | sort -u); do
      if [ ! -f "$BRAIN/presence/$_lnk.md" ] && [ ! -f "$BRAIN/connections/$_lnk.md" ] \
         && [ ! -f "$BRAIN/research/$_lnk.md" ]; then
        _warn "dangling link [[$_lnk]] in ${_f#"$BRAIN"/}"
      fi
    done
  done

  # stale-but-active (updated older than ~5 days) — secondary liveness hint, warning only
  _stale_cut=$(_days_ago 5)
  for _f in "$BRAIN"/presence/*.md; do
    [ -e "$_f" ] || continue
    [ "$(_fm "$_f" status)" = "active" ] || continue
    _up=$(_fm "$_f" updated)
    if [ -n "$_up" ] && [ -n "$_stale_cut" ] && [ "${_up%%T*}" \< "$_stale_cut" ]; then
      _warn "stale-active: $(_agent_slug "$_f") updated $_up (> ~5d) — confirm still active"
    fi
  done

  if [ "$_check_only" = 1 ]; then
    [ "$_errors" -gt 0 ] && return 1
    return 0
  fi

  # ── cheap auto-fixes (mutating) ──
  _me=$(cmd_whoami)
  if [ -n "$_me" ] && [ -f "$BRAIN/presence/$_me.md" ]; then
    _diff=$(git -C "$ROOT" diff --name-only "$(_main_ref)" 2>/dev/null | sort -u | tr '\n' ',' | sed 's/,$//;s/,/, /g')
    if [ -n "$_diff" ]; then
      _set_fm_inline "$BRAIN/presence/$_me.md" touches "[$_diff]"
      _set_fm_inline "$BRAIN/presence/$_me.md" updated "$(_now_iso)"
    fi
  fi

  # waiting-on liveness (blocker = features[] minus blocks[]; an external-only edge has no internal
  # blocker → never auto-touched). blocker done → resolve; blocker stale/abandoned → downgrade
  # open→watch so a blocked feature never sits stuck on a note nobody tends (M10).
  _stale_cut=$(_days_ago 5)
  for _c in "$BRAIN"/connections/*.md; do
    [ -e "$_c" ] || continue
    [ "$(_fm "$_c" kind)" = "waiting-on" ] || continue
    case "$(_fm "$_c" status)" in open|watch) ;; *) continue ;; esac
    _feats=$(_list_field "$_c" features); _blocked=$(_list_field "$_c" blocks)
    _resolved=0
    for _b in $_feats; do
      case " $_blocked " in *" $_b "*) continue ;; esac     # _b is blocked, not the blocker
      if [ -f "$BRAIN/presence/$_b.md" ] && [ "$(_fm "$BRAIN/presence/$_b.md" status)" = "done" ]; then
        _set_fm_inline "$_c" status resolved
        _set_fm_inline "$_c" resolved "$(_now_iso)"
        _set_fm_inline "$_c" updated "$(_now_iso)"
        cmd_announce "auto-resolved $(_agent_slug "$_c") — blocker '$_b' is done"
        _resolved=1; break
      fi
    done
    [ "$_resolved" = 1 ] && continue
    [ "$(_fm "$_c" status)" = "open" ] || continue          # only downgrade open edges
    for _b in $_feats; do
      case " $_blocked " in *" $_b "*) continue ;; esac
      [ -f "$BRAIN/presence/$_b.md" ] || continue
      [ "$(_fm "$BRAIN/presence/$_b.md" status)" = "done" ] && continue
      _bup=$(_fm "$BRAIN/presence/$_b.md" updated)
      if [ -n "$_bup" ] && [ -n "$_stale_cut" ] && [ "${_bup%%T*}" \< "$_stale_cut" ]; then
        _set_fm_inline "$_c" status watch
        _set_fm_inline "$_c" updated "$(_now_iso)"
        cmd_announce "downgraded $(_agent_slug "$_c") open→watch — blocker '$_b' appears abandoned (stale > ~5d); proceeding"
        break
      fi
    done
  done
  return 0
}

# date N days ago (YYYY-MM-DD); BSD and GNU date differ, try both
_days_ago() {
  date -u -v-"$1"d +%Y-%m-%d 2>/dev/null || date -u -d "$1 days ago" +%Y-%m-%d 2>/dev/null || true
}

# ── commit (durability; path-scoped, locked, secret-scanned, ff-only) ────────────────────────
cmd_commit() {
  _require_brain
  _lock_acquire commit || _die "another brain commit is in progress"
  # secret scan staged .brain/ content. Extra denylist terms (one per line, '#' comments ok) come
  # from $BRAIN_SECRET_DENYLIST or, by default, <vault>/secret-denylist.txt (optional — absent = skip).
  _deny="${BRAIN_SECRET_DENYLIST:-$BRAIN/secret-denylist.txt}"
  _hit=""
  for _f in $(git -C "$ROOT" ls-files --others --modified --exclude-standard -- .brain 2>/dev/null; \
              git -C "$ROOT" diff --cached --name-only -- .brain 2>/dev/null); do
    [ -f "$ROOT/$_f" ] || continue
    case "$_f" in .brain/bin/*|.brain/templates/*) continue ;; esac   # code/templates, not note content
    if grep -qE '^[A-Z][A-Z0-9_]*=.+' "$ROOT/$_f" 2>/dev/null; then _hit="$_f (env-shaped secret)"; break; fi
    if [ -f "$_deny" ]; then
      while IFS= read -r _term; do
        _term=$(printf '%s' "$_term" | sed 's/^[ -]*//;s/ *$//')
        [ -z "$_term" ] && continue
        case "$_term" in '#'*) continue ;; esac
        if grep -qiF "$_term" "$ROOT/$_f" 2>/dev/null; then _hit="$_f (denylisted: $_term)"; break 2; fi
      done < "$_deny"
    fi
  done
  if [ -n "$_hit" ]; then _lock_release commit; _die "secret-scan abort: $_hit"; fi

  git -C "$ROOT" add -- .brain 2>/dev/null
  if git -C "$ROOT" diff --cached --quiet -- .brain 2>/dev/null; then
    _lock_release commit; printf 'brain: nothing to commit\n'; return 0
  fi
  git -C "$ROOT" commit -q -m "chore(brain): sync coordination vault" -- .brain || { _lock_release commit; _die "commit failed"; }
  # ff-only rebase onto the fresh integration branch; never force-push (push is the caller's job)
  git -C "$ROOT" fetch -q "$(_main_remote)" "$(_main_branch)" 2>/dev/null && \
    git -C "$ROOT" rebase -q "$(_main_ref)" 2>/dev/null || \
    _warn "could not rebase onto $(_main_ref) (resolve manually before pushing)"
  _lock_release commit
  printf 'brain: committed .brain/ (chore(brain): sync coordination vault)\n'
}

# ── wrap (self-contained session closeout; wire into your own /wrap or run standalone) ─────────
cmd_wrap() {
  _require_brain
  _me=$(cmd_whoami)
  [ -n "$_me" ] || { printf 'brain: not a brain branch — nothing to wrap\n'; return 0; }
  printf 'brain: wrapping %s — update presence/%s.md live fields first (status/phase/touches).\n' "$_me" "$_me"
  cmd_reconcile                                    # self-heal settled/abandoned edges + refresh state
  if [ "$(_toplevel)" = "$ROOT" ]; then            # only the main-worktree session commits
    cmd_commit
  else
    printf 'brain: reconciled. commit skipped (sibling worktree) — the committer runs `brain commit` from %s.\n' "$ROOT"
  fi
}

# ── governance gauntlet ──────────────────────────────────────────────────────────────────────
cmd_propose() {
  _require_brain
  _type=${1:-}; shift 2>/dev/null || true; _desc="${*:-}"
  [ -n "$_type" ] && [ -n "$_desc" ] || _die "usage: brain propose <convention|machinery> \"<desc>\""
  _id=$(_kebab "$_desc")
  case "$_type" in
    machinery)
      # file a persistent watch connection (no feature-pair) + journal; keep working (human applies)
      _mf="$BRAIN/connections/machinery-$_id.md"
      _ts=$(_now_iso)
      cat > "$_mf" <<EOF
---
type: connection
features: []
kind: machinery
status: watch
severity: medium
blocks: []
files: []
discovered: $_ts
resolved: null
updated: $_ts
---
MACHINERY change proposed (human-applied in v1): $_desc
Agents keep working with current machinery until a human applies this deliberately.
EOF
      cmd_announce "machinery change proposed (human-applied in v1): $_id"
      printf 'brain: machinery proposal filed → %s (a human applies machinery in v1)\n' "${_mf#"$ROOT"/}"
      ;;
    convention)
      _lock_acquire governance || _die "a structural change is already in flight (lock held)"
      mkdir -p "$BRAIN/proposals"
      _pf="$BRAIN/proposals/$_id.md"
      _ts=$(_now_iso)
      cat > "$_pf" <<EOF
---
type: proposal
id: $_id
status: proposed
desc: $_desc
created: $_ts
---
CONVENTION change proposed (NOT yet live): $_desc
Validate + apply with: brain apply
EOF
      cmd_announce "convention change proposed: $_desc (id $_id)"
      printf 'brain: proposed convention "%s" (id %s) — not live. Apply: brain apply\n' "$_desc" "$_id"
      ;;
    *) _die "unknown proposal type: $_type (convention|machinery)" ;;
  esac
}

cmd_apply() {
  _require_brain
  _pf=""
  for _f in "$BRAIN"/proposals/*.md; do [ -e "$_f" ] && { _pf="$_f"; break; }; done
  [ -n "$_pf" ] || _die "no convention proposal in flight"
  _id=$(_fm "$_pf" id); [ -n "$_id" ] || _id=$(_agent_slug "$_pf")
  _desc=$(_fm "$_pf" desc)
  # auto-validate (reconcile dry-run); fail → reject + rollback
  if ! cmd_reconcile --check >/dev/null 2>&1; then
    rm -f "$_pf"; _lock_release governance
    _die "validation failed (reconcile --check) — proposal rolled back, nothing applied"
  fi
  # apply in lockstep: record in CHANGES, retire the proposal
  [ -f "$BRAIN/CHANGES.md" ] || printf '# Brain CHANGES — structural change log\n\n' > "$BRAIN/CHANGES.md"
  printf -- '- %s %s — %s\n' "$(_now_iso)" "$_id" "${_desc:-convention change}" >> "$BRAIN/CHANGES.md"
  mkdir -p "$BRAIN/proposals/applied"; mv "$_pf" "$BRAIN/proposals/applied/$_id.md"
  _lock_release governance
  printf 'brain: applied "%s" — recorded in CHANGES.md. Revert: brain revert %s\n' "$_id" "$_id"
}

cmd_revert() {
  _require_brain
  _id=${1:-}; [ -n "$_id" ] || _die "usage: brain revert <change-id|git-sha>"
  # git sha → git revert; else a recorded convention change → undo the record + retire
  if git -C "$ROOT" cat-file -e "$_id^{commit}" 2>/dev/null; then
    git -C "$ROOT" revert --no-edit "$_id" || _die "git revert failed"
    printf 'brain: reverted commit %s\n' "$_id"; return 0
  fi
  if [ -f "$BRAIN/CHANGES.md" ] && grep -q " $_id — " "$BRAIN/CHANGES.md"; then
    grep -v " $_id — " "$BRAIN/CHANGES.md" > "$BRAIN/CHANGES.md.tmp" && mv "$BRAIN/CHANGES.md.tmp" "$BRAIN/CHANGES.md"
    rm -f "$BRAIN/proposals/applied/$_id.md"
    cmd_announce "reverted convention change $_id"
    printf 'brain: reverted convention change %s (removed from CHANGES.md)\n' "$_id"; return 0
  fi
  _die "no change found for id: $_id"
}

# ── hooks ────────────────────────────────────────────────────────────────────────────────────
_emit_session_ctx() {
  jq -n --arg c "$1" \
    '{hookSpecificOutput:{hookEventName:"SessionStart",additionalContext:$c}}' 2>/dev/null \
    || printf '%s\n' "$1"
}
_emit_pretool() {
  # non-blocking: allow + surface the reason
  jq -n --arg r "$1" \
    '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"allow",permissionDecisionReason:$r}}' 2>/dev/null \
    || printf '%s\n' "$1"
}

_hook_session_start() {
  _feat=$(cmd_whoami)
  if [ -z "$_feat" ]; then
    # (a) self-onboard pre-check (fix C): feat/-shaped but no note → informational nudge
    _br=$(_branch); _slug=$(_slug_from_branch "$_br")
    case "$_br" in
      feat/*)
        # optional suppression list of non-brain globs
        if [ -f "$BRAIN/templates/non-brain-globs" ] && grep -qxF "$_br" "$BRAIN/templates/non-brain-globs" 2>/dev/null; then
          exit 0
        fi
        _emit_session_ctx "Agent Brain: branch '$_br' has no presence note. If this is a tracked feature, register it once: .brain/bin/brain new-feature $_slug"
        ;;
    esac
    exit 0                               # non-feature branch → silent
  fi
  # (c) cheap auto-fixes, robust to a never-wraps agent
  cmd_reconcile >/dev/null 2>&1 || true
  # (d) inject the protocol nudge + live state
  _st=$(cmd_status 2>/dev/null)
  _emit_session_ctx "Run the **navigation-standards** skill now (the Agent-Brain coordination protocol).

$_st"
  exit 0
}

_hook_pre_tool() {
  _input=$(cat 2>/dev/null)
  _feat=$(cmd_whoami); [ -z "$_feat" ] && exit 0          # allowlist: non-brain → silent
  _tool=$(printf '%s' "$_input" | jq -r '.tool_name // empty' 2>/dev/null)
  _cmd=$(printf '%s'  "$_input" | jq -r '.tool_input.command // empty' 2>/dev/null)
  _fp=$(printf '%s'   "$_input" | jq -r '.tool_input.file_path // empty' 2>/dev/null)

  _paths=""
  case "$_tool" in
    Bash)
      case "$_cmd" in
        *"git push"*|*"gh pr create"*) _paths=$(git -C "$ROOT" diff --name-only "$(_main_ref)" 2>/dev/null) ;;
        *) exit 0 ;;
      esac ;;
    Edit|Write|MultiEdit) [ -n "$_fp" ] && _paths=$(_relpath "$_fp") ;;
    *) exit 0 ;;
  esac
  [ -z "$_paths" ] && exit 0

  _collisions=$(_detect_collisions "$_feat" "$_paths")
  [ -z "$_collisions" ] && exit 0

  # durable record (also serves as the "about to PR / edit shared" journal line) — the guarantee
  cmd_announce "about to $_tool — shared-surface collision: $_collisions"

  # decision: non-blocking allow by default. ask is forbidden without an attached human (fix K).
  if [ "${BRAIN_PRETOOL_MODE:-allow}" = "ask" ] && [ -t 1 ]; then
    jq -n --arg r "Shared-surface collision: $_collisions. Coordinate before proceeding." \
      '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"ask",permissionDecisionReason:$r}}' 2>/dev/null
  else
    _emit_pretool "Shared-surface collision (proceeding; logged to journal): $_collisions"
  fi
  exit 0
}

_detect_collisions() {
  _me=$1; _paths=$2; _out=""
  for _p in $_paths; do
    for _o in "$BRAIN"/presence/*.md; do
      [ -e "$_o" ] || continue
      _os=$(_agent_slug "$_o"); [ "$_os" = "$_me" ] && continue
      case "$(_fm "$_o" status)" in active|blocked) ;; *) continue ;; esac   # live only
      for _t in $(_list_field "$_o" touches); do
        _path_match "$_p" "$_t" && _out="$_out $_os:$_t"
      done
    done
    for _c in "$BRAIN"/connections/*.md; do
      [ -e "$_c" ] || continue
      case "$(_fm "$_c" status)" in open|watch) ;; *) continue ;; esac
      for _cf in $(_list_field "$_c" files); do
        _path_match "$_p" "$_cf" && _out="$_out $(_agent_slug "$_c"):$_cf"
      done
    done
  done
  printf '%s\n' "$_out" | tr ' ' '\n' | sed '/^$/d' | sort -u | tr '\n' ' ' | sed 's/ *$//'
}

cmd_hook() {
  _ev=${1:-}
  ROOT=$(brain_root) 2>/dev/null || exit 0
  BRAIN="$ROOT/.brain"; [ -d "$BRAIN" ] || exit 0     # no brain → no-op (covers every other repo)
  case "$_ev" in
    session-start) ( _hook_session_start ) 2>>"$BRAIN/.hook-errors.log" || exit 0 ;;
    pre-tool)      ( _hook_pre_tool      ) 2>>"$BRAIN/.hook-errors.log" || exit 0 ;;
    *) exit 0 ;;
  esac
}

# ── install (machine-global pieces that do NOT travel with git) ───────────────────────────────
cmd_install() {
  ROOT=$(brain_root) || _die "not inside a git repository"
  BRAIN="$ROOT/.brain"
  _src="$BRAIN/templates/navigation-standards.SKILL.md"
  [ -f "$_src" ] || _die "missing nav-skill template (run brain init first): $_src"

  _skills="${BRAIN_SKILLS_DIR:-$HOME/.claude/skills}/navigation-standards"
  mkdir -p "$_skills"; cp "$_src" "$_skills/SKILL.md"

  _gs="${BRAIN_GLOBAL_SETTINGS:-$HOME/.claude/settings.json}"
  mkdir -p "$(dirname "$_gs")"; [ -f "$_gs" ] || printf '{}\n' > "$_gs"
  _disp_ss='d="$(git rev-parse --git-common-dir 2>/dev/null)" || exit 0; case "$d" in /*) ;; *) d="$(cd "$d" 2>/dev/null && pwd)" || exit 0;; esac; r="$(dirname "$d")"; [ -x "$r/.brain/bin/brain" ] && exec "$r/.brain/bin/brain" hook session-start || exit 0'
  _disp_pt='d="$(git rev-parse --git-common-dir 2>/dev/null)" || exit 0; case "$d" in /*) ;; *) d="$(cd "$d" 2>/dev/null && pwd)" || exit 0;; esac; r="$(dirname "$d")"; [ -x "$r/.brain/bin/brain" ] && exec "$r/.brain/bin/brain" hook pre-tool || exit 0'
  _tmp=$(mktemp)
  jq --arg ss "$_disp_ss" --arg pt "$_disp_pt" --arg dir "$BRAIN" --arg allow "Bash($BRAIN/bin/brain:*)" '
    .hooks = (.hooks // {}) |
    .hooks.SessionStart = (.hooks.SessionStart // []) |
    .hooks.PreToolUse = (.hooks.PreToolUse // []) |
    (if ([.hooks.SessionStart[]?.hooks[]?.command] | index($ss)) then .
     else .hooks.SessionStart += [{"hooks":[{"type":"command","command":$ss}]}] end) |
    (if ([.hooks.PreToolUse[]?.hooks[]?.command] | index($pt)) then .
     else .hooks.PreToolUse += [{"matcher":"Bash|Edit|Write|MultiEdit","hooks":[{"type":"command","command":$pt}]}] end) |
    .permissions = (.permissions // {}) |
    .permissions.additionalDirectories = ((.permissions.additionalDirectories // []) + [$dir] | unique) |
    .permissions.allow = ((.permissions.allow // []) + [$allow] | unique)
  ' "$_gs" > "$_tmp" && mv "$_tmp" "$_gs" || { rm -f "$_tmp"; _die "failed to merge global settings"; }

  printf 'brain: installed nav skill → %s\n' "$_skills/SKILL.md"
  printf 'brain: merged global dispatcher + allowlist → %s\n' "$_gs"
}

_write_project_settings() {
  # project .claude/settings.json: write-allowlist only (no hooks; hooks live in the global
  # dispatcher to avoid double-fire). .claude/settings.json is gitignored → main-worktree-local.
  _sf="$ROOT/.claude/settings.json"
  mkdir -p "$ROOT/.claude"; [ -f "$_sf" ] || printf '{}\n' > "$_sf"
  _tmp=$(mktemp)
  jq --arg dir "$BRAIN" --arg allow "Bash($BRAIN/bin/brain:*)" '
    .permissions = (.permissions // {}) |
    .permissions.additionalDirectories = ((.permissions.additionalDirectories // []) + [$dir] | unique) |
    .permissions.allow = ((.permissions.allow // []) + [$allow] | unique)
  ' "$_sf" > "$_tmp" && mv "$_tmp" "$_sf" || { rm -f "$_tmp"; _warn "could not write project settings"; }
}

# ── init (scaffold the brain into a repo) ────────────────────────────────────────────────────
cmd_init() {
  _force=0; _no_install=0
  for _a in "$@"; do
    case "$_a" in
      --force) _force=1 ;;
      --no-install) _no_install=1 ;;
    esac
  done
  ROOT=$(brain_root) || _die "not inside a git repository"
  BRAIN="$ROOT/.brain"
  _self_dir=$(cd "$(dirname "$0")" && pwd -P)     # the tool's bin/
  _tool_root=$(dirname "$_self_dir")              # ~/agent-brain (or an existing .brain)

  if [ -d "$BRAIN" ] && [ "$_force" = 0 ]; then
    printf 'brain: already initialized at %s (idempotent no-op; --force to re-template)\n' "$BRAIN"
  else
    mkdir -p "$BRAIN/bin" "$BRAIN/templates" "$BRAIN/presence" "$BRAIN/connections" \
             "$BRAIN/journal" "$BRAIN/research"
    # copy the engine + hook wrappers + templates from the source tool into the committed brain
    cp "$_tool_root/bin/"* "$BRAIN/bin/" 2>/dev/null || true
    chmod +x "$BRAIN/bin/"* 2>/dev/null || true
    cp "$_tool_root/templates/"* "$BRAIN/templates/" 2>/dev/null || true
    # static INDEX + CHANGES + reserved .indexignore (Phase 2)
    cp "$BRAIN/templates/INDEX.md" "$BRAIN/INDEX.md" 2>/dev/null || true
    [ -f "$BRAIN/CHANGES.md" ] || printf '# Brain CHANGES — structural change log\n\n' > "$BRAIN/CHANGES.md"
    printf 'templates/\nbin/\n' > "$BRAIN/.indexignore"
    # keep runtime artifacts + Obsidian config + the Phase-2 index DB out of commits
    printf '.obsidian/\n.cursors/\n.locks/\n.hook-fired/\n.hook-errors.log\nindex/\n*.db\n' > "$BRAIN/.gitignore"
    _day=$(_today); _jf="$BRAIN/journal/$_day.md"
    [ -f "$_jf" ] || { _new_journal "$_jf" "$_day"; \
      printf -- '- %s system — brain initialized. Agents: run the navigation-standards skill; query the brain yourself (pull, not push).\n' "$(_now_iso)" >> "$_jf"; }
    printf 'brain: scaffolded %s\n' "$BRAIN"
  fi

  _write_project_settings
  printf 'brain: wrote project write-allowlist → %s/.claude/settings.json\n' "$ROOT"

  if [ "$_no_install" = 0 ]; then
    cmd_install
  else
    printf 'brain: skipped machine-global install (--no-install). Run `brain install` to go live.\n'
  fi
  printf 'brain: NOTE — seed project features with `brain new-feature <slug>` (project-agnostic; no features hardcoded).\n'
}

usage() {
  cat <<'EOF'
brain — Agent Brain coordination vault (v1, filesystem-only)

  brain init [--force] [--no-install]   scaffold .brain/ into this repo
  brain install                         machine-global: nav skill + global hook dispatcher
  brain new-feature <slug>              register one feature (run once)
  brain whoami                          resolve the current feature (empty = not a brain branch)
  brain announce "<msg>"                append a line to today's journal
  brain status                          live dashboard (features, connections, banners)
  brain reconcile [--check]             validate + cheap auto-fixes (--check = validate only)
  brain commit                          durability: path-scoped, locked, secret-scanned, ff-only
  brain wrap                            self-contained closeout: reconcile + commit (from main)
  brain propose <convention|machinery> "<desc>"   governance gauntlet
  brain apply                           validate + apply the in-flight convention proposal
  brain revert <id|sha>                 undo a recorded change
  brain hook <session-start|pre-tool>   hook entry point (wired via settings)
EOF
}

# ── dispatch ─────────────────────────────────────────────────────────────────────────────────
_sub=${1:-}; [ $# -gt 0 ] && shift
case "$_sub" in
  init)        cmd_init "$@" ;;
  install)     cmd_install "$@" ;;
  new-feature) cmd_new_feature "$@" ;;
  whoami)      cmd_whoami "$@" ;;
  announce)    cmd_announce "$@" ;;
  status)      cmd_status "$@" ;;
  reconcile)   cmd_reconcile "$@" ;;
  commit)      cmd_commit "$@" ;;
  wrap)        cmd_wrap "$@" ;;
  propose)     cmd_propose "$@" ;;
  apply)       cmd_apply "$@" ;;
  revert)      cmd_revert "$@" ;;
  hook)        cmd_hook "$@" ;;
  version|--version) printf 'brain %s\n' "$VERSION" ;;
  ''|help|-h|--help) usage ;;
  *) _warn "unknown subcommand: $_sub"; usage; exit 1 ;;
esac
